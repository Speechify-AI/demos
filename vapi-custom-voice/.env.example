SPEECHIFY_API_KEY=sk_your_speechify_key_here

# Optional. Defaults to :8772 in run.sh.
SHIM_ADDR=:8772

# Optional. Pins the tts-shims revision used by run.sh.
# This is the vapi provider PR head until it lands on main.
SHIM_REF=d84f0f04eabd08e281a1541f8914c5293691a54f

# Optional. Vapi sends this to the shim as X-VAPI-SECRET when you configure server.secret.
VAPI_SECRET=replace_with_a_random_secret

# Vapi custom TTS supports 8000, 16000, 22050, and 24000. This demo uses 24000
# because Speechify's PCM stream path is verified at 24 kHz.
VAPI_SAMPLE_RATE=24000
