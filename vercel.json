{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "site": {
      "root": "site/",
      "buildCommand": "pnpm run build",
      "outputDirectory": "public"
    },
    "next-voice-cloning-app": {
      "root": "demos/next-voice-cloning-app/",
      "framework": "nextjs"
    },
    "turnstile": {
      "root": "services/turnstile/"
    }
  },
  "rewrites": [
    {
      "source": "/api/turnstile/:path*",
      "destination": { "service": "turnstile", "path": "/api/:path*" }
    },
    {
      "source": "/next-voice-cloning-app/:path*",
      "destination": { "service": "next-voice-cloning-app" }
    },
    {
      "source": "/",
      "destination": { "service": "site", "path": "/index.html" }
    },
    {
      "source": "/:path*",
      "destination": { "service": "site" }
    }
  ]
}
