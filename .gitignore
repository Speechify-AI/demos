# env files (never commit secrets)
.env
.env.*
!.env.example

# Node
node_modules/
package-lock.json
yarn.lock
dist/
.next/
out/
.turbo/
*.tsbuildinfo
.npmrc
# pnpm-lock.yaml is intentionally committed: Vercel's Turborepo build requires a
# committed lockfile, and it fails the deploy if it is missing or out of date.

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
uv.lock

# Runtime artifacts not worth committing
*.log

# ffmpeg concat manifest contains absolute paths, regenerated by concat.sh on every run
audiobook-pipeline/output/**/manifest.txt

# Editors / OS
.DS_Store
.vscode/
.idea/

.vercel
