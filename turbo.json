{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "../demos/*/demo.json", "../vercel.json", "../scripts/generate.mjs"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**", "public/index.html"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
